name: body-eye-sync
version: "{{ version }}"
installer_type: exe

company: SSC
uninstall_name: body-eye-sync

channels:
  - conda-forge

# A minimal base: Python + pip + menuinst. The application and all of its
# dependencies (including CUDA torch) are pip-installed by post_install.bat from
# the shipped, fully-pinned, hashed lockfile - so they are NOT listed here.
specs:
  - python 3.13.*
  - pip
  - menuinst

# This is a self-contained application, not a Python distribution: never offer to
# register the installed Python as the system Python, run `conda init`, or record
# the environment in the user's conda environment list.
register_python: false
initialize_conda: false
register_envs: false

# Drop the conda package cache from the install directory once installed.
keep_pkgs: false

# Copied into the install prefix for post_install.bat to consume (it deletes the
# wheel + lockfile afterwards).
extra_files:
  - requirements-win.lock
  - body_eye_sync-{{ version }}-py3-none-any.whl
  - menu.json

post_install: post_install.bat
post_install_desc: "Downloading and installing required components - this can take several minutes..."
pre_uninstall: pre_uninstall.bat

conclusion_text: "body-eye-sync has been installed. Launch it from the Start menu or desktop shortcut."
welcome_image: ../resources/installer_image.png
header_image: ../resources/header_image.png
icon_image: ../src/body_eye_sync/gui/resources/icon.ico
license_file: ../LICENSE.md
